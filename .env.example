# Plataforma: auto | x86 | rpi (auto detecta Raspberry Pi vs PC)
PLATFORM=auto

# --- Fuente de video ---
# local = webcam | stream = RTSP/HTTP remoto | tuya = cámara Smart Life (Cloud API)
VIDEO_SOURCE=local
# STREAM_URL=rtsp://192.168.1.100:8554/unicast
# Si el stream falla en local, usa cámara como respaldo (true/false)
STREAM_FALLBACK_LOCAL=true
RTSP_TRANSPORT=tcp
STREAM_RECONNECT_SEC=5
STREAM_BUFFER_SIZE=1
STREAM_MAX_FAILURES=30
# Timeout lectura RTSP en ms (OpenCV/FFmpeg; por defecto 5000, evita bloqueos de 30s)
# STREAM_READ_TIMEOUT_MS=5000
# STREAM_OPEN_TIMEOUT_MS=10000
# Opciones extra FFmpeg (formato key;value|key;value). Ej: allowed_media_types;video
# STREAM_FFMPEG_OPTIONS=

# Cámara local (solo si VIDEO_SOURCE=local o sin STREAM_URL)
CAMERA_INDEX=0
CAMERA_WIDTH=
CAMERA_HEIGHT=
CAMERA_BACKEND=

# --- Detección ---
# Movimiento: OpenCV MOG2 | Personas/objetos: YOLOv8
MOTION_THRESHOLD=25
MIN_MOTION_AREA=
YOLO_CONFIDENCE=
DETECTION_INTERVAL_SEC=
NOTIFICATION_COOLDOWN_SEC=60
SAVE_SNAPSHOTS=true
SNAPSHOT_DIR=snapshots
# Retención (también configurable en /admin → Capturas; 0 = sin límite)
SNAPSHOT_RETENTION_DAYS=30
SNAPSHOT_MAX_PER_CAMERA=500
SNAPSHOT_CLEANUP_INTERVAL_SEC=3600

# YOLOv8 — clases COCO a detectar (IDs separados por coma)
# all = todas las clases | vacío = conjunto por defecto (personas, vehículos, animales...)
# Ejemplo solo personas y coches: DETECT_CLASSES=0,2
DETECT_CLASSES=
YOLO_MODEL=yolov8n.pt
YOLO_DEVICE=
YOLO_IMGSZ=
YOLO_ON_MOTION_ONLY=

SHOW_PREVIEW=

# Interfaz web (activada por defecto en contenedor)
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
DATA_DIR=data

# --- Email (SMTP) ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password
EMAIL_FROM=tu_correo@gmail.com
EMAIL_TO=destino@gmail.com

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp (Twilio) ---
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+34600123456

# --- Tuya IoT (opcional; también configurable en /admin → Tuya IoT) ---
# Proyecto en https://platform.tuya.com/ con cuenta Smart Life vinculada
TUYA_ACCESS_ID=
TUYA_ACCESS_KEY=
TUYA_UID=
TUYA_API_REGION=eu
# TUYA_API_ENDPOINT=
# TUYA_STREAM_TYPE=rtsp
