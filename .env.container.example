# Copia a .env y ajusta STREAM_URL
# cp .env.example .env

# Fuente RTSP (v4l2rtspserver u otro)
VIDEO_SOURCE=stream
STREAM_URL=rtsp://192.168.1.100:8554/unicast
RTSP_TRANSPORT=tcp

# Contenedor: sin ventana, CPU
CONTAINER=1
SHOW_PREVIEW=false
YOLO_DEVICE=cpu
PLATFORM=auto

SHOW_PREVIEW=false
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080

DETECTION_INTERVAL_SEC=1.0
NOTIFICATION_COOLDOWN_SEC=60
SAVE_SNAPSHOTS=true
SNAPSHOT_DIR=/app/snapshots

# UID/GID del usuario en el host (Podman rootless). Ejecuta: id -u / id -g
HOST_UID=1000
HOST_GID=1000

# Multi-servicio (compose por defecto)
# WORKER_TOKEN=

# Notificaciones (activa las que uses)
EMAIL_ENABLED=false
TELEGRAM_ENABLED=false
WHATSAPP_ENABLED=false
